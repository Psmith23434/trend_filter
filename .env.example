# ─── LLM Provider ───────────────────────────────────────────────────────────
# Default is 'ollama' (free, local). No API key needed.
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama settings (only if LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3

# OpenAI (only if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ─── Phase 4 API Keys (optional, not needed for MVP) ────────────────────────
# Reddit official API
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=trend_filter/0.1

# YouTube Data API v3
# YOUTUBE_API_KEY=

# Product Hunt
# PRODUCT_HUNT_API_KEY=

# ─── Database (Phase 2) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/trend_filter

# ─── Scoring weights ────────────────────────────────────────────────────────
SCORE_WEIGHT_GROWTH=0.30
SCORE_WEIGHT_DIVERSITY=0.20
SCORE_WEIGHT_COMMERCIAL=0.20
SCORE_WEIGHT_NOVELTY=0.15
SCORE_WEIGHT_PERSISTENCE=0.15

# ─── Scheduler ──────────────────────────────────────────────────────────────
PIPELINE_INTERVAL_MINUTES=60
