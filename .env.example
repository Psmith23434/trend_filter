# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trend_filter

# ── Scheduler ─────────────────────────────────────────────────────────────────
Enable background scheduler (set true in production)
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_MINUTES=60

# ── Scoring weights (must sum to 1.0) ──────────────────────────────────────────
W_GROWTH=0.30
W_DIVERSITY=0.20
W_COMMERCIAL=0.20
W_NOVELTY=0.15
W_PERSISTENCE=0.15

# Urgency thresholds
URGENCY_HIGH=0.70
URGENCY_MED=0.45

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-20240307

# ── API keys (all optional — free sources work without them) ───────────────────
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendFilter/1.0
PRODUCT_HUNT_TOKEN=
